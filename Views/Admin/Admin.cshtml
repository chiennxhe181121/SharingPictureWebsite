@using SharingPictureWebsite.ViewModels
@model AdminDashboardViewModel


<!-- Header -->
<div class="mb-8">
	<h1 class="text-3xl font-bold mb-2 text-gray-900">Admin Dashboard</h1>
	<p class="text-gray-600">Manage users and monitor system activity</p>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
	<div class="bg-white rounded-lg shadow-md p-6">
		<div class="flex items-center justify-between mb-2">
			<h3 class="text-sm font-semibold text-gray-600 uppercase">Total Users</h3>
			<div class="p-2 bg-blue-100 rounded-lg">
				<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
				</svg>
			</div>
		</div>
		<p id="totalUsers" class="text-3xl font-semibold text-gray-900">@Model.Stats.TotalUsers</p>
		<p id="activeUsersText" class="text-sm text-gray-500 mt-1">@Model.Stats.ActiveUsers active</p>
	</div>

	<div class="bg-white rounded-lg shadow-md p-6">
		<div class="flex items-center justify-between mb-2">
			<h3 class="text-sm font-semibold text-gray-600 uppercase">Total Images</h3>
			<div class="p-2 bg-green-100 rounded-lg">
				<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
				</svg>
			</div>
		</div>
		<p id="totalImages" class="text-3xl font-semibold text-gray-900">@Model.Stats.TotalImages</p>
		<p id="approvedImagesText" class="text-sm text-gray-500 mt-1">@Model.Stats.ApprovedImages approved</p>
	</div>

	<div class="bg-white rounded-lg shadow-md p-6">
		<div class="flex items-center justify-between mb-2">
			<h3 class="text-sm font-semibold text-gray-600 uppercase">Active Users</h3>
			<div class="p-2 bg-green-100 rounded-lg">
				<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
				</svg>
			</div>
		</div>
		<p id="activeUsers" class="text-3xl font-semibold text-gray-900">@Model.Stats.ActiveUsers</p>
		<p id="activePercentText" class="text-sm text-gray-500 mt-1">@Model.Stats.ActivePercent% of total</p>
	</div>

	<div class="bg-white rounded-lg shadow-md p-6">
		<div class="flex items-center justify-between mb-2">
			<h3 class="text-sm font-semibold text-gray-600 uppercase">Banned Users</h3>
			<div class="p-2 bg-red-100 rounded-lg">
				<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
				</svg>
			</div>
		</div>
		<p id="bannedUsers" class="text-3xl font-semibold text-gray-900">@Model.Stats.BannedUsers</p>
		<p id="bannedPercentText" class="text-sm text-gray-500 mt-1">@Model.Stats.BannedPercent% of total</p>
	</div>
</div>

<!-- Members Table -->
<div class="bg-white rounded-lg shadow-md overflow-hidden">
	<div class="px-6 py-4 border-b border-gray-200">
		<h2 class="text-xl font-semibold text-gray-900">Member Management</h2>
	</div>

	<div class="overflow-x-auto">
		<table class="w-full">
			<thead class="bg-gray-50 border-b border-gray-200">
				<tr>
					<th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Username</th>
					<th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Email</th>
					<th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Role</th>
					<th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Status</th>
					<th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Actions</th>
				</tr>
			</thead>
			<tbody id="membersTable" class="divide-y divide-gray-200">
				@foreach (var member in Model.Members.Items)
				{
					var isBanned = member.Status == Status.Banned;
					var statusClass = isBanned ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800";
					var statusText = isBanned ? "Banned" : "Active";

					<tr class="hover:bg-gray-50">
						<td class="px-6 py-4 text-sm font-medium text-gray-900">@member.MemberName</td>
						<td class="px-6 py-4 text-sm text-gray-600">@member.Email</td>
						<td class="px-6 py-4 text-sm text-gray-600">@(member.Role?.RoleName ?? "-")</td>
						<td class="px-6 py-4">
							<span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @statusClass">@statusText</span>
						</td>
						<td class="px-6 py-4">
							<div class="flex gap-2">
								@if (!isBanned)
								{
									<form asp-action="Ban" asp-controller="Admin" asp-route-id="@member.MemberID" method="post" class="inline">
										<input type="hidden" name="page" value="@Model.Members.CurrentPage" />
										<button type="submit" class="p-2 rounded-full bg-red-100 text-red-700 hover:bg-red-200 transition-colors" title="Ban" aria-label="Ban user">
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636"></path>
											</svg>
										</button>
									</form>
								}
								else
								{
									<button type="button" disabled class="p-2 rounded-full bg-gray-100 text-gray-400 cursor-not-allowed" title="User already banned" aria-label="User already banned">
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636"></path>
										</svg>
									</button>
								}

								@if (isBanned)
								{
									<form asp-action="Unban" asp-controller="Admin" asp-route-id="@member.MemberID" method="post" class="inline">
										<input type="hidden" name="page" value="@Model.Members.CurrentPage" />
										<button type="submit" class="p-2 rounded-full bg-green-100 text-green-700 hover:bg-green-200 transition-colors" title="Unban" aria-label="Unban user">
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
											</svg>
										</button>
									</form>
								}
								else
								{
									<button type="button" disabled class="p-2 rounded-full bg-gray-100 text-gray-400 cursor-not-allowed" title="User is active" aria-label="User is active">
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
									</button>
								}
							</div>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>

@if (Model.Members.TotalPages > 1)
{
	<div class="mt-6 flex justify-center items-center gap-2">
		@if (Model.Members.HasPreviousPage)
		{
			<a href="/admin?page=1" class="px-3 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300">First</a>
			<a href="/admin?page=@(Model.Members.CurrentPage - 1)" class="px-3 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300">Previous</a>
		}

		@for (int i = 1; i <= Model.Members.TotalPages; i++)
		{
			@if (i == Model.Members.CurrentPage)
			{
				<span class="px-3 py-2 rounded bg-blue-600 text-white font-semibold">@i</span>
			}
			else if (i >= Model.Members.CurrentPage - 2 && i <= Model.Members.CurrentPage + 2)
			{
				<a href="/admin?page=@i" class="px-3 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300">@i</a>
			}
			else if (i == Model.Members.CurrentPage - 3 || i == Model.Members.CurrentPage + 3)
			{
				<span class="px-2 py-2">...</span>
			}
		}

		@if (Model.Members.HasNextPage)
		{
			<a href="/admin?page=@(Model.Members.CurrentPage + 1)" class="px-3 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300">Next</a>
			<a href="/admin?page=@Model.Members.TotalPages" class="px-3 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300">Last</a>
		}
	</div>
}

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const success = @Html.Raw(Json.Serialize(TempData["Success"]));
		const error = @Html.Raw(Json.Serialize(TempData["Error"]));

		if (success) {
			Swal.fire({
				icon: 'success',
				title: 'Success',
				text: success,
				timer: 2500,
				showConfirmButton: false
			});
		}

		if (error) {
			Swal.fire({
				icon: 'error',
				title: 'Error',
				text: error,
				timer: 2500,
				showConfirmButton: false
			});
		}
	});
</script>