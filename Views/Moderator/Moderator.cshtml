@model IEnumerable<Picture>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SharingPicture - Moderator Review</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50">

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold mb-2 text-gray-900">Moderator Review</h1>
            <p class="text-gray-600">Review and approve submitted images</p>
        </div>

        <!-- Filter -->
        <div class="bg-white rounded-lg shadow-md p-4 mb-6">
            <div class="flex items-center gap-4 flex-wrap">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                    </svg>
                    <span class="font-semibold text-gray-900">Filter:</span>
                </div>
                <div class="flex gap-2">
                    <button onclick="filterImages('all')" id="filter-all" class="px-4 py-2 rounded-lg bg-blue-600 text-white transition-colors">
                        All (<span id="count-all">0</span>)
                    </button>
                    <button onclick="filterImages('pending')" id="filter-pending" class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
                        Pending (<span id="count-pending">0</span>)
                    </button>
                    <button onclick="filterImages('approved')" id="filter-approved" class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
                        Approved (<span id="count-approved">0</span>)
                    </button>
                    <button onclick="filterImages('rejected')" id="filter-rejected" class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
                        Rejected (<span id="count-rejected">0</span>)
                    </button>
                </div>
            </div>
        </div>

        <!-- Images Table -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Image</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Title</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Uploader</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Upload Date</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Status</th>
                            <th class="action-col px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="imagesTable" class="divide-y divide-gray-200">
                        @foreach (var picture in Model)
                        {
                            var normalizedStatus = picture.Status switch
                            {
                                Status.Pending => "pending",
                                Status.Rejected => "rejected",
                                Status.Banned => "rejected",
                                _ => "approved"
                            };

                            var statusBadgeClass = normalizedStatus switch
                            {
                                "pending" => "bg-yellow-100 text-yellow-800",
                                "rejected" => "bg-red-100 text-red-800",
                                _ => "bg-green-100 text-green-800"
                            };

                            var statusLabel = normalizedStatus switch
                            {
                                "pending" => "Pending",
                                "rejected" => "Rejected",
                                _ => "Approved"
                            };

                            <tr data-status="@normalizedStatus" class="hover:bg-gray-50">
                                <td class="px-6 py-4">
                                    <img src="@picture.ImageURL" alt="@picture.Title" class="w-20 h-14 object-cover rounded-md cursor-pointer" onclick="showImageModal('@picture.ImageURL')" />
                                </td>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">@picture.Title</td>
                                <td class="px-6 py-4 text-sm text-gray-600">@(picture.Author?.MemberName ?? "Unknown")</td>
                                <td class="px-6 py-4 text-sm text-gray-600">@picture.UploadDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @statusBadgeClass">@statusLabel</span>
                                </td>
                                <td class="action-col px-6 py-4">
                                    <div class="flex gap-2">
                                        <form asp-action="Approve" asp-controller="Moderator" asp-route-id="@picture.PictureID" method="post" class="inline">
                                            <button type="submit" class="px-3 py-1 rounded bg-green-100 text-green-700 text-sm hover:bg-green-200">Approve</button>
                                        </form>
                                        <form asp-action="Reject" asp-controller="Moderator" asp-route-id="@picture.PictureID" method="post" class="inline">
                                            <button type="submit" class="px-3 py-1 rounded bg-red-100 text-red-700 text-sm hover:bg-red-200">Reject</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div id="noResults" class="hidden text-center py-12 text-gray-500">
                No images found
            </div>
        </div>
    </main>

    <!-- Image Preview Modal -->
    <div id="imageModal" class="hidden fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-50 p-4" onclick="closeModal()">
        <div class="max-w-4xl max-h-[90vh] overflow-auto">
            <img id="modalImage" src="" alt="Preview" class="w-full h-auto rounded-lg" onclick="event.stopPropagation()" />
        </div>
    </div>

    <script>
        let currentFilter = 'all';

        function updateCounts() {
            const tbody = document.getElementById('imagesTable');
            const rows = tbody.querySelectorAll('tr');

            const counts = {
                all: rows.length,
                pending: 0,
                approved: 0,
                rejected: 0
            };

            rows.forEach(row => {
                const status = row.getAttribute('data-status');
                if (counts[status] !== undefined) {
                    counts[status]++;
                }
            });

            document.getElementById('count-all').textContent = counts.all;
            document.getElementById('count-pending').textContent = counts.pending;
            document.getElementById('count-approved').textContent = counts.approved;
            document.getElementById('count-rejected').textContent = counts.rejected;
        }

        // Filter functionality
        function filterImages(status) {
            currentFilter = status;

            const actionCols = document.querySelectorAll('.action-col');
            const shouldHideAction = status !== 'pending';
            actionCols.forEach(col => {
                col.style.display = shouldHideAction ? 'none' : 'table-cell';
            });

            // Update filter buttons
            ['all', 'pending', 'approved', 'rejected'].forEach(s => {
                const btn = document.getElementById(`filter-${s}`);
                if (s === status) {
                    btn.className = 'px-4 py-2 rounded-lg bg-blue-600 text-white transition-colors';
                } else {
                    btn.className = 'px-4 py-2 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors';
                }
            });

            // Filter table rows
            const tbody = document.getElementById('imagesTable');
            const rows = tbody.querySelectorAll('tr');
            let visibleCount = 0;

            rows.forEach(row => {
                const statusCell = row.getAttribute('data-status');
                if (status === 'all' || statusCell === status) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Show/hide no results message
            const noResults = document.getElementById('noResults');
            if (visibleCount === 0) {
                noResults.classList.remove('hidden');
            } else {
                noResults.classList.add('hidden');
            }
        }

        // Image preview modal
        function showImageModal(url) {
            document.getElementById('modalImage').src = url;
            document.getElementById('imageModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('imageModal').classList.add('hidden');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            updateCounts();
            filterImages('all');

            const success = @Html.Raw(Json.Serialize(TempData["Success"]));
            const error = @Html.Raw(Json.Serialize(TempData["Error"]));

            if (success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Thanh cong',
                    text: success,
                    timer: 2500,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '/gallery';
                });
            }

            if (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Loi',
                    text: error,
                    timer: 2500,
                    showConfirmButton: false
                });
            }
        });
    </script>
</body>
</html>