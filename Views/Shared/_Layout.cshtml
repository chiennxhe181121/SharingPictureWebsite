@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var memberRole = User.IsInRole("Admin") ? "Admin" :
                     User.IsInRole("Moderator") ? "Moderator" :
                     User.IsInRole("Member") ? "Member" : null;

    var memberName = User.Identity?.IsAuthenticated == true
                     ? User.FindFirst("MemberName")?.Value
                     : "Guest";

    var avatarUrl = User.Identity?.IsAuthenticated == true
                    ? User.FindFirst("AvatarUrl")?.Value ?? "/images/user/default-avatar.jpg"
                    : "/images/user/default-avatar.jpg";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-ink: #0f172a;
            --brand-soft: #334155;
            --brand-primary: #0369a1;
            --brand-primary-soft: #e0f2fe;
            --brand-card: rgba(255, 255, 255, 0.88);
            --brand-border: rgba(148, 163, 184, 0.25);
        }

        .glass-card {
            background: var(--brand-card);
            border: 1px solid var(--brand-border);
            box-shadow: 0 20px 40px -30px rgba(15, 23, 42, 0.45);
            backdrop-filter: blur(6px);
        }

        .filter-pill {
            transition: all 180ms ease;
        }

            .filter-pill:hover {
                transform: translateY(-1px);
            }

        .fade-in {
            animation: fadeUp 450ms ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .nav-link {
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Hiệu ứng thanh trượt dưới chân (tùy chọn nếu không muốn dùng nền trắng) */
        .nav-link-active {
            color: #2563eb !important;
        }

        /* Đổ bóng cho text logo */
        .logo-text {
            text-shadow: 0 2px 10px rgba(37, 99, 235, 0.1);
        }

        /* Làm mịn backdrop filter */
        .glass-nav {
            backdrop-filter: blur(12px) saturate(180%);
            -webkit-backdrop-filter: blur(12px) saturate(180%);
        }

        body {
            font-family: 'Sora', sans-serif;
            color: var(--brand-ink);
            background-color: #f8fafc; /* Màu nền cơ bản */
        }

        /* 🔥 BACKGROUND SIÊU ĐẸP & SÂU */
        .fancy-background {
            position: fixed;
            inset: 0;
            z-index: -10;
            /* 1. Dải màu chuyển Linear nhẹ nhàng */
            background-image: linear-gradient(135deg, #f0f9ff 0%, #ffffff 50%, #eef2ff 100%);
        }

            .fancy-background::before,
            .fancy-background::after {
                content: "";
                position: absolute;
                border-radius: 100%;
                filter: blur(100px); /* Làm nhòe cực mạnh để tạo hiệu ứng mờ kính */
                opacity: 0.15; /* Làm mờ đi để không bị chói */
                z-index: -11;
            }

            /* Vòng tròn màu xanh dương ở góc trên trái */
            .fancy-background::before {
                width: 600px;
                height: 600px;
                background-color: #3b82f6;
                top: -100px;
                left: -100px;
            }

            /* Vòng tròn màu tím ở góc dưới phải */
            .fancy-background::after {
                width: 500px;
                height: 500px;
                background-color: #818cf8;
                bottom: -150px;
                right: -100px;
            }
    </style>
</head>

<body class="min-h-screen relative custom-scrollbar">

    <div class="fancy-background"></div>
    
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 glass-nav bg-white/70 border-b border-white/40 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <a asp-controller="Gallery" asp-action="Index" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 bg-gradient-to-tr from-blue-600 to-indigo-500 rounded-xl flex items-center justify-center shadow-lg shadow-blue-200 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <span class="text-xl font-black tracking-tight logo-text bg-gradient-to-r from-gray-900 to-gray-600 bg-clip-text text-transparent">
                        SHARING<span class="text-blue-600">PIX</span>
                    </span>
                </a>

                <div class="hidden md:flex items-center bg-gray-100/50 backdrop-blur-md p-1.5 rounded-2xl border border-gray-200/50">

                    <a asp-action="Index" asp-controller="Gallery"
                       class="nav-link flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold
       @(currentController == "Gallery" ? "bg-white text-blue-600 shadow-sm" : "text-gray-500 hover:text-gray-900")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Discovery
                    </a>

                    @{
                        var uploadAction = memberRole == null ? "Login" : "Upload";
                        var uploadController = memberRole == null ? "Auth" : "Picture";
                    }
                    <a asp-action="@uploadAction" asp-controller="@uploadController"
                       class="nav-link flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold
       @(currentController == "Picture" ? "bg-white text-blue-600 shadow-sm" : "text-gray-500 hover:text-gray-900")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Upload
                    </a>

                    @if (memberRole == "Moderator")
                    {
                        <a asp-action="Moderator" asp-controller="Moderator"
                           class="nav-link flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold
               @(currentController == "Moderator" ? "bg-white text-blue-600 shadow-sm" : "text-gray-500 hover:text-gray-900")">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            Moderate
                        </a>
                    }

                    @if (memberRole == "Admin")
                    {
                        <a asp-action="Admin" asp-controller="Admin"
                           class="nav-link flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold
               @(currentController == "Admin" ? "bg-white text-blue-600 shadow-sm" : "text-gray-500 hover:text-gray-900")">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            </svg>
                            Admin
                        </a>
                    }
                </div>

                <div class="flex items-center gap-4">
                    @if (memberRole == null)
                    {
                        <div class="flex items-center gap-1 bg-white/50 backdrop-blur-sm p-1 rounded-full border border-gray-200 shadow-sm transition-all">

                            <a asp-action="Login" asp-controller="Auth"
                               class="px-6 py-2 rounded-full transition-all text-sm font-bold
               @(currentAction == "Login"
                                            ? "bg-blue-600 text-white shadow-md shadow-blue-100"
                                            : "text-gray-500 hover:text-blue-600")">
                                                                                   Sign in
                                                                               </a>

                            <a asp-action="Register" asp-controller="Auth"
                               class="px-6 py-2 rounded-full transition-all text-sm font-bold
               @(currentAction == "Register"
                                            ? "bg-blue-600 text-white shadow-md shadow-blue-100"
                                            : "text-gray-500 hover:text-blue-600")">
                            Sign up
                        </a>

                        </div>
                                        }
                    else
                    {
                        <div class="relative" x-data="{ open: false }">
                            <button @@click="open = !open" @@click.away="open = false"
                                    class="flex items-center gap-3 p-1 pr-4 rounded-full border border-gray-200 bg-white/80 hover:bg-white hover:shadow-md transition-all group">
                                <div class="relative">
                                    <img src="@avatarUrl" alt="Avatar"
                                         class="w-9 h-9 rounded-full object-cover border-2 border-white shadow-sm group-hover:border-blue-200 transition-colors">
                                    <div class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></div>
                                </div>
                                <div class="flex flex-col items-start leading-none">
                                    <span class="text-[10px] text-blue-600 font-bold uppercase tracking-wider">@memberRole</span>
                                    <span class="font-bold text-gray-700 text-sm">@memberName</span>
                                </div>
                                <svg class="w-4 h-4 text-gray-400 transition-transform duration-300" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>

                            <div x-show="open"
                                 x-transition:enter="transition ease-out duration-200"
                                 x-transition:enter-start="opacity-0 scale-95 translate-y-2"
                                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                                 x-transition:leave="transition ease-in duration-75"
                                 class="absolute right-0 mt-3 w-48 glass-card bg-white/95 rounded-2xl overflow-hidden z-50 py-1.5 border border-white shadow-2xl">

                                <form method="get" asp-action="Logout" asp-controller="Auth">
                                    <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors font-bold">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                                        Sign Out
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 pt-10 pb-24">
        @RenderBody()
    </main>
</body>
</html>