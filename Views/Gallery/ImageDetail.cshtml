@model SharingPictureWebsite.ViewModels.ImageDetailViewModel

<div class="mb-8 bg-white/60 backdrop-blur-md rounded-2xl border border-white/40 shadow-sm p-3">
    <div class="flex items-center justify-between w-full px-2">

        <nav class="flex items-center gap-2">
            <a asp-controller="Gallery" asp-action="Index"
               class="flex items-center gap-2 px-4 py-2 bg-white text-blue-600 rounded-xl shadow-sm border border-blue-50 text-sm font-bold transition-all hover:bg-blue-50 hover:scale-[1.02]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Discovery
            </a>

            <svg class="w-4 h-4 text-gray-300 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>

            <span class="text-sm font-black text-gray-800 tracking-tight px-2 truncate max-w-[200px] sm:max-w-[400px]">
                @Model.Title
            </span>
        </nav>

        <a asp-controller="Gallery" asp-action="Index"
           class="flex items-center gap-2 px-4 py-1.5 bg-blue-600 text-white text-xs font-bold rounded-xl hover:bg-blue-700 hover:-translate-x-1 transition-all duration-300">
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
            BACK
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 fade-in p-2">
    <div class="lg:col-span-2 space-y-8 bg-white/40 backdrop-blur-md p-6 rounded-3xl border border-white/40 shadow-xl">

        <div class="relative group overflow-hidden rounded-2xl shadow-2xl bg-black/5">
            <img id="mainImage" src="@Model.ImageURL"
                 onerror="this.onerror=null;this.src='/images/default-image.jpg';"
                 alt="@Model.Title"
                 class="w-full h-auto object-contain max-h-[75vh] mx-auto transition-transform duration-500 group-hover:scale-[1.01]" />

            <div class="absolute bottom-4 right-4">
                <button id="likeBtn" onclick="toggleLike()"
                        class="flex items-center gap-2 px-5 py-2.5 rounded-full backdrop-blur-md shadow-lg transition-all duration-300 @(Model.IsLiked ? "bg-red-500 text-white" : "bg-white/90 text-gray-700 hover:bg-white")">
                    <svg id="likeIcon" class="w-5 h-5" fill="@(Model.IsLiked ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                    <span class="font-bold text-sm" id="likeCount">@Model.LikeCount</span>
                </button>
            </div>
            <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <button type="button"
                        onclick="downloadImage(event, '@Model.ImageURL', '@Model.Title')"
                        class="p-3 bg-black/40 hover:bg-blue-600 backdrop-blur-md rounded-2xl text-white border border-white/20 shadow-xl transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                </button>
            </div>
        </div>

        <div class="h-[1px] bg-gradient-to-r from-transparent via-gray-300 to-transparent opacity-50"></div>

        <div class="space-y-6">
            <h3 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                <span class="w-2 h-6 bg-blue-500 rounded-full"></span>
                Comments (<span id="commentCount">@Model.CommentTotal</span>)
            </h3>

            <form id="commentForm" class="relative group">
                <input type="text" id="commentInput" placeholder="Share your thoughts..."
                       class="w-full pl-5 pr-24 py-4 bg-white/60 border-none rounded-2xl focus:ring-2 focus:ring-blue-400 shadow-inner placeholder:text-gray-400 transition-all" />
                <button type="submit" class="absolute right-2 top-2 bottom-2 px-6 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-all shadow-md active:scale-95">
                    Post
                </button>
            </form>
            <div id="commentsList" class="space-y-4 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar"></div>
            <button id="loadMoreComments" class="w-full py-2 mt-2 text-sm font-bold text-blue-600 hover:underline">Load more</button>
        </div>
    </div>

    <div class="lg:col-span-1">
        <div class="sticky top-24 space-y-4">
            <div class="bg-white/70 backdrop-blur-md rounded-3xl p-8 shadow-xl border border-white/40 fade-in">
                <h2 id="imageTitle" class="text-2xl font-black text-gray-900 mb-6 leading-tight tracking-tight">
                    @Model.Title
                </h2>

                <div id="imageInfo" class="space-y-4 mb-8">
                    <div class="flex items-center gap-3 p-3 bg-blue-50/50 rounded-2xl border border-blue-100/50">
                        <div class="p-2 bg-blue-500 rounded-lg text-white shadow-sm">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"></path></svg>
                        </div>
                        <div>
                            <p class="text-[10px] uppercase text-gray-400 font-bold">Category</p>
                            <p class="text-gray-700 font-semibold">@Model.CategoryName</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-3 p-3 bg-purple-50/50 rounded-2xl border border-purple-100/50">
                        <div class="p-2 bg-purple-500 rounded-lg text-white shadow-sm">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
                        </div>
                        <div>
                            <p class="text-[10px] uppercase text-gray-400 font-bold">Author</p>
                            <p class="text-gray-700 font-semibold">@Model.AuthorName</p>
                        </div>
                    </div>

                    <p class="text-[11px] text-center text-gray-400 italic pt-2">
                        Uploaded on @Model.CreatedAt.ToString("MMM dd, yyyy")
                    </p>
                </div>

                <div id="imageDescription" class="pt-6 border-t border-gray-100">
                    <h4 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Description</h4>
                    <div class="p-4 bg-gray-50/50 rounded-2xl italic text-gray-600 text-sm leading-relaxed">
                        "@Model.Description"
                    </div>
                </div>

                <div class="pt-8 space-y-3">
                    <button type="button"
                            onclick="downloadImage(event, '@Model.ImageURL', '@Model.Title')"
                            class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black shadow-lg shadow-blue-100 hover:bg-blue-700 hover:-translate-y-1 transition-all active:scale-95 flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        Download Full Asset
                    </button>

                    <p class="text-[10px] text-center text-gray-400 font-medium px-4">
                        By downloading, you agree to the community licensing terms.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom Scrollbar cho danh sách comment */
    .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.05);
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.1);
        }
</style>

<script>
    // Khởi tạo dữ liệu từ Model
    let isLiked = @Model.IsLiked.ToString().ToLower();
    let likeCount = @Model.LikeCount;

    async function toggleLike() {
        const pictureId = @Model.PictureID;
        const likeBtn = document.getElementById('likeBtn');
        const likeIcon = document.getElementById('likeIcon');
        const likeCountSpan = document.getElementById('likeCount');

        try {
            const response = await fetch(`/Gallery/image/${pictureId}/like`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                }
            });

            if (response.status === 401) {
                // redirect sang login
                window.location.href = '/login';
                return;
            }

            if (!response.ok) throw new Error('Network response was not ok');

            const data = await response.json();
            isLiked = data.isLiked;
            likeCount = data.likeCount;

            if (isLiked) {
                likeBtn.classList.remove('bg-white/90', 'text-gray-700');
                likeBtn.classList.add('bg-red-500', 'text-white');
                likeIcon.setAttribute('fill', 'currentColor');
            } else {
                likeBtn.classList.remove('bg-red-500', 'text-white');
                likeBtn.classList.add('bg-white/90', 'text-gray-700');
                likeIcon.setAttribute('fill', 'none');
            }
            likeCountSpan.textContent = likeCount;

        } catch (err) {
            console.error('Error when liking photos:', err);
        }
    }

    // Comment form handler
    const commentForm = document.getElementById('commentForm');
    if (commentForm) {
    // Comment form
    commentForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = document.getElementById('commentInput');
        const content = input.value.trim();
        if (!content) return;

        const pictureId = @Model.PictureID;
        try {
            const response = await fetch(`/Gallery/image/${pictureId}/comment`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify({ content })
            });

            if (response.status === 401) {
                window.location.href = '/login';
                return;
            }

            if (!response.ok) throw new Error('Network response was not ok');

            const data = await response.json();
            if (data.success) {
                // thêm comment vào UI
                const commentsList = document.getElementById('commentsList');
                const commentEl = document.createElement('div');
                commentEl.className = "p-4 bg-white/80 rounded-2xl border border-white/50 shadow-sm hover:shadow-md transition-all flex gap-3";
                commentEl.innerHTML = `
                    <img src="${data.comment.avatarUrl}" alt="${data.comment.userName}" class="w-8 h-8 rounded-full object-cover flex-shrink-0">
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-1">
                            <span class="font-bold text-blue-600 text-sm">${data.comment.userName}</span>
                            <span class="text-[10px] text-gray-400 uppercase tracking-widest font-medium">${data.comment.createdAt}</span>
                        </div>
                        <p class="text-gray-700 leading-relaxed text-sm">${data.comment.content}</p>
                    </div>
                `;
                commentsList.prepend(commentEl);
                input.value = '';
                const commentCountEl = document.getElementById('commentCount');
                commentCountEl.textContent = parseInt(commentCountEl.textContent) + 1;
            }
        } catch (err) {
            console.error('Error when submitting a comment:', err);
        }
    });
    }

        async function downloadImage(event, url, fileName) {
        event.preventDefault(); // Ngăn default action của button
        event.stopPropagation(); // Ngăn bubble lên <a> cha

        try {
            const response = await fetch(url);
            const blob = await response.blob();

            const blobUrl = window.URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = blobUrl;
            link.download = fileName + '.jpg';

            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            window.URL.revokeObjectURL(blobUrl);
        } catch (error) {
            console.error("Lỗi khi tải ảnh:", error);
            window.open(url, '_blank'); // fallback
        }
    }

        let currentCommentPage = 1;
    const pageSize = 5; // giống backend

    async function loadComments(page = 1) {
        try {
            const response = await fetch(`/Gallery/image/@Model.PictureID/comments?page=${page}`);
            if (!response.ok) throw new Error('Network response was not ok');

            const data = await response.json();
            const commentsList = document.getElementById('commentsList');

            data.comments.forEach(c => {
                const commentEl = document.createElement('div');
                commentEl.className = "p-4 bg-white/80 rounded-2xl border border-white/50 shadow-sm hover:shadow-md transition-all flex gap-3";
                commentEl.innerHTML = `
                    <img src="${c.avatarUrl}" alt="${c.userName}" class="w-8 h-8 rounded-full object-cover flex-shrink-0">
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-1">
                            <span class="font-bold text-blue-600 text-sm">${c.userName}</span>
                            <span class="text-[10px] text-gray-400 uppercase tracking-widest font-medium">${c.createdAt}</span>
                        </div>
                        <p class="text-gray-700 leading-relaxed text-sm">${c.content}</p>
                    </div>
                `;
                commentsList.appendChild(commentEl);
            });

            // Nếu đã load hết, ẩn nút Load more
            if (commentsList.children.length >= data.total) {
                document.getElementById('loadMoreComments').style.display = 'none';
            }

        } catch (err) {
            console.error('Error loading comments:', err);
        }
    }

    // Load comment đầu tiên
    loadComments(currentCommentPage);

    // Bắt sự kiện nút Load More
    document.getElementById('loadMoreComments').addEventListener('click', () => {
        currentCommentPage++;
        loadComments(currentCommentPage);
    });
</script>